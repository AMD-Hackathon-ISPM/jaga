# Serving weights are committed so a fresh clone runs end-to-end (all files < 100 MB).
!/modelServerandTraining/GemmaServer/models/
!/modelServerandTraining/GemmaServer/models/**
/modelServerandTraining/GemmaServer/models/yamnet/1.tflite
# WavLM int8 embedder is ~355 MB (exceeds GitHub's 100 MB limit) — generate it with
# quantizenigga/quantize.py or fetch out-of-band; the .gitkeep keeps the dir tracked.
/modelServerandTraining/GemmaServer/models/wavlm/*.onnx
!/modelServerandTraining/PrismaServer/app/models/local_clahe/checkpoints/best.pt
