STACK_NAME=jaga
NGINX_PUBLISHED_PORT=80

GO_API_IMAGE=jaga/go-api:local
PRISMA_WORKER_IMAGE=jaga/prisma-worker:local
WEB_IMAGE=jaga/web:local
NGINX_IMAGE=jaga/nginx:local
POSTGRES_IMAGE=jaga/postgres:local
REDIS_IMAGE=jaga/redis:local
MINIO_IMAGE=jaga/minio:local
YAMNET_IMAGE=jaga/yamnet:local
XGBOOST_IMAGE=jaga/xgboost:local
PRISMA_WORKER_PORT=8000
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_ENABLE_ASSISTANT=true
NEXT_PUBLIC_ENABLE_PRISMA=true

POSTGRES_DB=jaga
POSTGRES_USER=jaga
POSTGRES_PASSWORD=change-me

REDIS_PASSWORD=change-me

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_BUCKET_UPLOADS=uploads
MINIO_BUCKET_MODELS=models

# Gemma chat/orchestration provider: fireworks (default) or featherless.
LLM_PROVIDER=fireworks

FEATHERLESS_URL=https://api.featherless.ai/v1
FEATHERLESS_API_KEY=change-me
FEATHERLESS_MODEL=zai-org/GLM-5.2
# Gemma model served by Featherless (used when LLM_PROVIDER=featherless).
FEATHERLESS_CHAT_MODEL=google/gemma-2-9b-it

# Fireworks AI: Gemma (chat/orchestration) + WavLM (audio embeddings).
FIREWORKS_API_KEY=change-me
FIREWORKS_CHAT_URL=https://api.fireworks.ai/inference/v1/chat/completions
FIREWORKS_CHAT_MODEL=accounts/ezzeddinpratama04/deployments/od9nvbmy
FIREWORKS_EMBEDDING_URL=https://api.fireworks.ai/inference/v1/embeddings
FIREWORKS_EMBEDDING_MODEL=accounts/ezzeddinpratama04/deployments/txvxdq5w

# Prisma CXR worker.
PRISMA_THRESHOLD=0.5
# Grad-CAM explainability overlay in the CXR response (set false to disable).
PRISMA_GRADCAM=true

# Rust model services.
COUGH_THRESHOLD=0.5
DEFAULT_COUNTRY=PH
# Local WavLM int8 is the primary embedder; fall back to Fireworks if it runs
# longer than this many seconds (or errors / is missing).
LOCAL_EMBED_TIMEOUT_SECS=15
# Path to the ONNX Runtime shared library inside the Rust service images.
ORT_DYLIB_PATH=/usr/local/lib/libonnxruntime.so

JWT_SECRET=change-me

UPLOAD_PATH=/var/lib/jaga/uploads
MODEL_PATH=/models
