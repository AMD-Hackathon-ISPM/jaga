# Jaga frontend environment (example)
#
# NEXT_PUBLIC_* flags are baked in at build time. Set them before `next build`.
# Base URL for the Go API gateway. Leave empty for same-origin routing.
NEXT_PUBLIC_API_BASE_URL=

NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_MODE=fixture
# Prototype capabilities default to on; set false to hide Help or CXR upload.
NEXT_PUBLIC_ENABLE_ASSISTANT=true
NEXT_PUBLIC_ENABLE_PRISMA=true
